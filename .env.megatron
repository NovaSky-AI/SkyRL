export UV_CACHE_DIR=/opt/dlami/nvme/uv-cache-suhaschundi
export UV_PROJECT_ENVIRONMENT=/opt/dlami/nvme/skyrl-venv-suhaschundi
export UV_PYTHON=3.12

SKYRL_SRC=/mnt/efs/suhaschundi/SkyRL
SYNC_MARKER=$UV_PROJECT_ENVIRONMENT/.synced
if [[ ! -d "$UV_PROJECT_ENVIRONMENT" \
   || "$SKYRL_SRC/uv.lock" -nt "$SYNC_MARKER" \
   || "$SKYRL_SRC/pyproject.toml" -nt "$SYNC_MARKER" ]]; then
  echo "[env.megatron] syncing venv to NVMe at $UV_PROJECT_ENVIRONMENT..."
  mkdir -p "$UV_CACHE_DIR"
  (cd "$SKYRL_SRC" && uv sync --frozen) && touch "$SYNC_MARKER"
fi

# Ensure vllm is present: lock/source-override conflict makes uv silently
# skip vllm on fresh venvs. Install PyPI 0.19 as a baseline; swap to local
# editable for VLM runs that need a newer version.
if ! "$UV_PROJECT_ENVIRONMENT/bin/python" -c "import vllm" 2>/dev/null; then
  echo "[env.megatron] installing vllm baseline..."
  uv pip install --python "$UV_PROJECT_ENVIRONMENT/bin/python" "vllm==0.19.0" --no-deps
fi
unset SKYRL_SRC SYNC_MARKER

export CUDNN_PATH=$UV_PROJECT_ENVIRONMENT/lib/python3.12/site-packages/nvidia/cudnn
export CPATH=$CUDNN_PATH/include:$CPATH
export LIBRARY_PATH=$CUDNN_PATH/lib:$LIBRARY_PATH
export LD_LIBRARY_PATH=$CUDNN_PATH/lib:$LD_LIBRARY_PATH
export LD_LIBRARY_PATH=$(python -c 'import os, glob; print(":".join(sorted(set(os.path.dirname(p) for p in glob.glob(os.environ["UV_PROJECT_ENVIRONMENT"] + "/lib/python3.12/site-packages/nvidia/*/lib/*.so*")))))'):$LD_LIBRARY_PATH

export CUDA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7
export NVIDIA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7
export RAY_enable_metrics_agent=0
